# Kalshi API (get from kalshi.com → Account → Profile → API Keys)
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem
KALSHI_BASE_URL=https://demo-api.kalshi.co/trade-api/v2

# Trading mode: "paper" (safe), "cautious" (1 contract, tight limits), "normal" (full)
TRADING_MODE=paper

# FRED API (get free key from fred.stlouisfed.org)
FRED_API_KEY=

# Twitter/X API (optional)
TWITTER_BEARER_TOKEN=

# Telegram notifications (create bot via @BotFather, get chat ID via @userinfobot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Strategy Parameters (base values — effective values depend on TRADING_MODE)
PROBABILITY_THRESHOLD=0.05
MIN_EDGE_AFTER_FEES=0.02
MAX_POSITION_PER_MARKET=20
MAX_DAILY_LOSS=25
MAX_PORTFOLIO_EXPOSURE=75
KELLY_FRACTION=0.25
